{
  "name": "rct-platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "pip install -e . && pip install -r requirements.txt && pip install -r requirements-dev.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "yzhang.markdown-all-in-one",
        "squidfunk.vscode-mdx",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["-v", "--tb=short"],
        "editor.formatOnSave": true,
        "editor.rulers": [100],
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  },
  "forwardPorts": [8000, 8080],
  "portsAttributes": {
    "8000": {
      "label": "RCT Control Plane API",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "MkDocs Documentation",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "RCT_ENV": "development",
    "RCT_LOG_LEVEL": "DEBUG"
  }
}
